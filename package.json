{
	"name": "extension-for-graphics",
	"version": "1.1.1",
	"private": true,
	"description": "Prolo browser extension for Graphics",
	"author": "Technology - Graphic HTML",
	"type": "module",
	"scripts": {
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"compile": "tsc --noEmit",
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"postinstall": "wxt prepare",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox"
	},
	"dependencies": {
		"jszip": "^3.10.1",
		"papaparse": "^5.5.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-loader-spinner": "8.0.2",
		"react-spinners": "^0.17.0",
		"sweetalert": "^2.1.2",
		"sweetalert2": "^11.26.23"
	},
	"devDependencies": {
		"@stacksjs/bumpx": "0.2.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@wxt-dev/module-react": "^1.2.2",
		"prettier": "^3.8.1",
		"sass-embedded": "^1.98.0",
		"typescript": "^5.9.3",
		"wxt": "^0.20.19"
	}
}
